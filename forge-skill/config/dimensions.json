{
  "dimensions": [
    {
      "id": "correctness",
      "name": "正确性",
      "color": "#10B981",
      "description": "代码能否正确执行",
      "metrics": ["pass_rate", "compilation", "runtime_errors"]
    },
    {
      "id": "security",
      "name": "安全性",
      "color": "#EF4444",
      "description": "代码是否存在安全漏洞",
      "metrics": ["vulnerability_count", "cwe_list"]
    },
    {
      "id": "maintainability",
      "name": "可维护性",
      "color": "#0EA5E9",
      "description": "代码的可读性和可维护程度",
      "metrics": ["cyclomatic_complexity", "lines_of_code", "comment_ratio"]
    },
    {
      "id": "robustness",
      "name": "鲁棒性",
      "color": "#F59E0B",
      "description": "代码对边界情况的处理",
      "metrics": ["edge_case_handling", "null_check", "exception_handling"]
    },
    {
      "id": "performance",
      "name": "性能",
      "color": "#6366F1",
      "description": "代码执行效率",
      "metrics": ["execution_time", "memory_usage", "cpu_usage"]
    }
  ]
}